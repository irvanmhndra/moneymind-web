# MoneyMind Frontend Configuration
# Copy this file to .env and update the values

# API Configuration
VITE_API_BASE_URL=http://localhost:8080/api/v1

# App Configuration
VITE_APP_NAME=MoneyMind
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Personal Finance Management Application

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_OCR=true
VITE_ENABLE_SPLIT_EXPENSES=true
VITE_ENABLE_BUDGETS=true
VITE_ENABLE_GOALS=true
VITE_ENABLE_EXPORT=true

# Upload Configuration
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# Development
VITE_ENABLE_DEVTOOLS=true
VITE_LOG_LEVEL=debug